<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Void Theme - "Empty Space" -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0A0514" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#0F0A1E" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#140F28" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#190F50" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#140F2D" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#140F28" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#281E46" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#B4AADC" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#6E648C" />
    <SolidColorBrush x:Key="AccentBrush" Color="#8C64DC" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#190F50" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#8C5DE2" />
    <SolidColorBrush x:Key="CommentBrush" Color="#7152B3" />
    <SolidColorBrush x:Key="StringBrush" Color="#F39C12" />
    <SolidColorBrush x:Key="NumberBrush" Color="#BCAEF1" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#8C5DE2" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFD700" />
    <SolidColorBrush x:Key="BracketColor2" Color="#DA70D6" />
    <SolidColorBrush x:Key="BracketColor3" Color="#6A5ACD" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#281E46" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#190F50" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#140F28" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#281E46" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#190F50" />
    
</ResourceDictionary>