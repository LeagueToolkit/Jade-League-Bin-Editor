<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ForestGreen Theme - "Emerald Envy" -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#142319" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#192D1E" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#1E3223" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#228B22" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#233C2D" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#1E3223" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#32553C" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#C8E6D2" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#78A08C" />
    <SolidColorBrush x:Key="AccentBrush" Color="#64DC96" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#228B22" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#5DE2A2" />
    <SolidColorBrush x:Key="CommentBrush" Color="#51B386" />
    <SolidColorBrush x:Key="StringBrush" Color="#F39C12" />
    <SolidColorBrush x:Key="NumberBrush" Color="#AEF1CE" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#5DE2A2" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFD700" />
    <SolidColorBrush x:Key="BracketColor2" Color="#DA70D6" />
    <SolidColorBrush x:Key="BracketColor3" Color="#00FF7F" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#32553C" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#228B22" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#1E3223" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#32553C" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#228B22" />
    
</ResourceDictionary>