<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- PastelBlue Theme - "Azure Dream" -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E6F5FF" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#D2F0FF" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#FFF0FA" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#50C8FF" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#EEFBFF" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#EBE1FF" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#A0E6FF" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#4682B4" />
    <SolidColorBrush x:Key="AccentBrush" Color="#00BFFF" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#40000000" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#50C8FF" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#4169E1" />
    <SolidColorBrush x:Key="CommentBrush" Color="#6495ED" />
    <SolidColorBrush x:Key="StringBrush" Color="#FF8C00" />
    <SolidColorBrush x:Key="NumberBrush" Color="#4682B4" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#50C8FF" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#00BFFF" />
    <SolidColorBrush x:Key="BracketColor2" Color="#4169E1" />
    <SolidColorBrush x:Key="BracketColor3" Color="#4682B4" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#A0E6FF" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#50C8FF" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#EBE1FF" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#A0E6FF" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#50C8FF" />
    
</ResourceDictionary>