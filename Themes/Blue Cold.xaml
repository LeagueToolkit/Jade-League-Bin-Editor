<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Blue Cold Theme -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0F1928" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#141E2D" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#19232E" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#005A9E" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E2D41" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#19232E" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#2D415A" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#DCE6F0" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#788CA0" />
    <SolidColorBrush x:Key="AccentBrush" Color="#64B4DC" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#005A9E" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#5DADE2" />
    <SolidColorBrush x:Key="CommentBrush" Color="#52BE80" />
    <SolidColorBrush x:Key="StringBrush" Color="#F39C12" />
    <SolidColorBrush x:Key="NumberBrush" Color="#AED6F1" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#5DADE2" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFD700" />
    <SolidColorBrush x:Key="BracketColor2" Color="#DA70D6" />
    <SolidColorBrush x:Key="BracketColor3" Color="#00BFFF" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2D415A" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#005A9E" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#19232E" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#2D415A" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#005A9E" />
    
</ResourceDictionary>