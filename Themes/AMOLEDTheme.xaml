<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- AMOLED Theme - "Absolute Black" -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#0A0A0A" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#141414" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0A0A0A" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#0A0A0A" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#1E1E1E" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#B4B4B4" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#646464" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FFFFFF" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#1EFFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#FFFFFF" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#D4D4D4" />
    <SolidColorBrush x:Key="CommentBrush" Color="#606060" />
    <SolidColorBrush x:Key="StringBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="NumberBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#D4D4D4" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BracketColor2" Color="#B4B4B4" />
    <SolidColorBrush x:Key="BracketColor3" Color="#646464" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#333333" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#0A0A0A" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#333333" />
    
</ResourceDictionary>