<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- VioletSorrow Theme - "Deep Despair" -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#120A23" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#160C2A" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#1C1234" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#411E78" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#201439" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#1C1234" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#4B3273" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#B9AAD7" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#78669E" />
    <SolidColorBrush x:Key="AccentBrush" Color="#8E64DC" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#411E78" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#8E5DE2" />
    <SolidColorBrush x:Key="CommentBrush" Color="#7252B3" />
    <SolidColorBrush x:Key="StringBrush" Color="#F39C12" />
    <SolidColorBrush x:Key="NumberBrush" Color="#BDAEF1" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#8E5DE2" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFD700" />
    <SolidColorBrush x:Key="BracketColor2" Color="#DA70D6" />
    <SolidColorBrush x:Key="BracketColor3" Color="#9370DB" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#4B3273" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#411E78" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#1C1234" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#4B3273" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#411E78" />
    
</ResourceDictionary>