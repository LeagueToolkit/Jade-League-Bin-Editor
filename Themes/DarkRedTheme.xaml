<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- DarkRed Theme - "Red Rage" -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#280F14" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#2D1419" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#32191E" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#9E0028" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#3C1E23" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#32191E" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#5A2D37" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F0DDE1" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#A07882" />
    <SolidColorBrush x:Key="AccentBrush" Color="#DC6482" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#9E0028" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#E25D5D" />
    <SolidColorBrush x:Key="CommentBrush" Color="#BE5252" />
    <SolidColorBrush x:Key="StringBrush" Color="#F39C12" />
    <SolidColorBrush x:Key="NumberBrush" Color="#F1AEAE" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#E25D5D" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFD700" />
    <SolidColorBrush x:Key="BracketColor2" Color="#DA70D6" />
    <SolidColorBrush x:Key="BracketColor3" Color="#FF4500" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#5A2D37" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#9E0028" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#32191E" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#5A2D37" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#9E0028" />
    
</ResourceDictionary>