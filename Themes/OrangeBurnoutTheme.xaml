<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- OrangeBurnout Theme - "Solar Flare" -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#230F05" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#2A1408" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#32190A" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#CC5500" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#3C1E0F" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#32190A" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#6E2D0F" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFE4D1" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#A07864" />
    <SolidColorBrush x:Key="AccentBrush" Color="#DC8C64" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#CC5500" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#E29C5D" />
    <SolidColorBrush x:Key="CommentBrush" Color="#BE8C52" />
    <SolidColorBrush x:Key="StringBrush" Color="#F39C12" />
    <SolidColorBrush x:Key="NumberBrush" Color="#F1D2AE" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#E29C5D" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFD700" />
    <SolidColorBrush x:Key="BracketColor2" Color="#DA70D6" />
    <SolidColorBrush x:Key="BracketColor3" Color="#FF8C00" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#6E2D0F" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#CC5500" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#32190A" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#6E2D0F" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#CC5500" />
    
</ResourceDictionary>