<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Obicna tema obriase ce ie druge al je daytfulyt  -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#252526" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#505050" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D2D30" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#252526" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#3E3E42" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#D4D4D4" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#808080" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4EC9B0" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#007ACC" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#569CD6" />
    <SolidColorBrush x:Key="CommentBrush" Color="#6A9955" />
    <SolidColorBrush x:Key="StringBrush" Color="#CE9178" />
    <SolidColorBrush x:Key="NumberBrush" Color="#B5CEA8" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#9CDCFE" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFD700" />
    <SolidColorBrush x:Key="BracketColor2" Color="#DA70D6" />
    <SolidColorBrush x:Key="BracketColor3" Color="#87CEFA" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3E3E42" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#505050" />
    
    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#252526" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#3E3E42" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#505050" />
    
    <!-- Code Folding Margin Colors -->
    <SolidColorBrush x:Key="FoldingMargin.FoldingMarkerBackgroundBrush" Color="#2D2D30" />
    <SolidColorBrush x:Key="FoldingMargin.FoldingMarkerBrush" Color="#808080" />
    <SolidColorBrush x:Key="FoldingMargin.SelectedFoldingMarkerBackgroundBrush" Color="#3E3E42" />
    <SolidColorBrush x:Key="FoldingMargin.SelectedFoldingMarkerBrush" Color="#D4D4D4" />
    
</ResourceDictionary>