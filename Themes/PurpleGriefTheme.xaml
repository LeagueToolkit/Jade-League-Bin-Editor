<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- PurpleGrief Theme - "Amethyst Ache" -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#190F1E" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1E1423" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#231928" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#462850" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#281E2D" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#231928" />
    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#50325A" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#DCC8E6" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#9078A0" />
    <SolidColorBrush x:Key="AccentBrush" Color="#A064DC" />
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#462850" />
    
    <!-- Syntax Highlighting Colors -->
    <SolidColorBrush x:Key="KeywordBrush" Color="#BE5DE2" />
    <SolidColorBrush x:Key="CommentBrush" Color="#9B52B3" />
    <SolidColorBrush x:Key="StringBrush" Color="#F39C12" />
    <SolidColorBrush x:Key="NumberBrush" Color="#D9AEF1" />
    <SolidColorBrush x:Key="PropertyBrush" Color="#BE5DE2" />
    
    <!-- Bracket Colors -->
    <SolidColorBrush x:Key="BracketColor1" Color="#FFD700" />
    <SolidColorBrush x:Key="BracketColor2" Color="#DA70D6" />
    <SolidColorBrush x:Key="BracketColor3" Color="#BA55D3" />
    
    <!-- UI Element Colors -->
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#50325A" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#462850" />

    <!-- Scrollbar Colors -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#231928" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#50325A" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#462850" />
    
</ResourceDictionary>