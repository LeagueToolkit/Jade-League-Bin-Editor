<Window x:Class="Jade.Windows.ParticlePanelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Jade.Windows"
        Title="Particle Panel" Height="750" Width="950"
        Background="Transparent"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Border BorderThickness="1" BorderBrush="{DynamicResource SubtleBorderBrush}" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}" Height="35" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" CornerRadius="{DynamicResource GlobalCornerRadius}">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                         <TextBlock Text="✨" Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="14"/>
                        <TextBlock Text="Particle Editor" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0">
                         <Button x:Name="RefreshButton" Content="🔄" Width="35" Height="35" Click="RefreshButton_Click" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryTextBrush}" ToolTip="Refresh from Editor" Style="{StaticResource WindowControlButtonStyle}" FontSize="16"/>
                         <Button x:Name="CloseButton" Content="✕" Width="35" Height="35" Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryTextBrush}" Style="{StaticResource WindowControlButtonStyle}" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Tree View of Systems/Emitters -->
                <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="10">
                            <TextBlock Text="Systems &amp; Emitters" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                            <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Style="{DynamicResource ModernTextBox}" Tag="Search entries..." Height="30"/>
                        </StackPanel>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="5,0">
                            <TreeView x:Name="SystemTree" Background="Transparent" BorderThickness="0" SelectedItemChanged="SystemTree_SelectedItemChanged">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="{x:Type TreeViewItem}">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <Setter Property="Padding" Value="4,6"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type local:ParticleSystemItem}" ItemsSource="{Binding Emitters}">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                    </HierarchicalDataTemplate>
                                    <DataTemplate DataType="{x:Type local:ParticleEmitterItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="◆" FontSize="10" Margin="0,0,8,0" Opacity="0.5" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                        </ScrollViewer>
                        
                        <Border Grid.Row="2" Padding="10" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SubtleBorderBrush}">
                             <TextBlock x:Name="TreeStatusText" Text="Ready" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Right: Editing Controls -->
                <Grid Grid.Column="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="EditorPanel" Visibility="Collapsed">
                            
                            <!-- Header -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="EDITING PROPERTY" FontSize="12" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="SelectedEmitterText" Text="Emitter Name" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Birth Scale & Scale -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Birth Scale -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Birth Scale" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="BirthScaleX" Grid.Column="0" Style="{DynamicResource ModernTextBox}" Tag="BirthScaleX" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                        <TextBox x:Name="BirthScaleY" Grid.Column="2" Style="{DynamicResource ModernTextBox}" Tag="BirthScaleY" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                        <TextBox x:Name="BirthScaleZ" Grid.Column="4" Style="{DynamicResource ModernTextBox}" Tag="BirthScaleZ" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                    </Grid>
                                    <Grid Margin="2,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="X" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock Grid.Column="2" Text="Y" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock Grid.Column="4" Text="Z" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Scale -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Scale" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ScaleX" Grid.Column="0" Style="{DynamicResource ModernTextBox}" Tag="ScaleX" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                        <TextBox x:Name="ScaleY" Grid.Column="2" Style="{DynamicResource ModernTextBox}" Tag="ScaleY" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                        <TextBox x:Name="ScaleZ" Grid.Column="4" Style="{DynamicResource ModernTextBox}" Tag="ScaleZ" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                    </Grid>
                                     <Grid Margin="2,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="X" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock Grid.Column="2" Text="Y" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock Grid.Column="4" Text="Z" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- Translation Override -->
                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="Translation Override" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TransX" Grid.Column="0" Style="{DynamicResource ModernTextBox}" Tag="TransX" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                    <TextBox x:Name="TransY" Grid.Column="2" Style="{DynamicResource ModernTextBox}" Tag="TransY" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                    <TextBox x:Name="TransZ" Grid.Column="4" Style="{DynamicResource ModernTextBox}" Tag="TransZ" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                </Grid>
                                <Grid Margin="2,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="X" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                    <TextBlock Grid.Column="2" Text="Y" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                    <TextBlock Grid.Column="4" Text="Z" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Lifetimes & Weight -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Properties" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="15">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Particle Lifetime -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Particle Lifetime" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5"/>
                                                <TextBox x:Name="ParticleLifetimeBox" Style="{DynamicResource ModernTextBox}" Tag="ParticleLifetime" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                            </StackPanel>
                                            
                                            <!-- Particle Linger -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Particle Linger" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5"/>
                                                <TextBox x:Name="ParticleLingerBox" Style="{DynamicResource ModernTextBox}" Tag="ParticleLinger" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Bind Weight -->
                                        <TextBlock Text="Bind Weight" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="BindWeightBox" Grid.Column="0" Style="{DynamicResource ModernTextBox}" Tag="BindWeight" KeyUp="Input_KeyUp" LostFocus="Input_LostFocus"/>
                                            
                                            <Button Grid.Column="2" Content="0" Click="SetWeightZero_Click" Width="40" Padding="0" Height="28" Style="{DynamicResource ModernButtonStyle}" FontSize="12"/>
                                            <Button Grid.Column="4" Content="1" Click="SetWeightOne_Click" Width="40" Padding="0" Height="28" Style="{DynamicResource ModernButtonStyle}" FontSize="12"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <!-- Utility Actions -->
                             <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Utility Actions" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="15">
                                    <WrapPanel>
                                        <Button Content="x2 Scale" Click="DoubleScale_Click" Margin="0,0,10,10" Style="{DynamicResource ModernButtonStyle}"/>
                                        <Button Content="/2 Scale" Click="HalfScale_Click" Margin="0,0,10,10" Style="{DynamicResource ModernButtonStyle}"/>
                                        <Button Content="+Add BindWeight" Click="AddWeight_Click" Margin="0,0,10,10" Style="{DynamicResource ModernButtonStyle}"/>
                                        <Button Content="+Add Translation" Click="AddTranslation_Click" Margin="0,0,10,10" Style="{DynamicResource ModernButtonStyle}"/>
                                    </WrapPanel>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyStatePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="✨" FontSize="48" HorizontalAlignment="Center" Opacity="0.1" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="No Emitter Selected" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
