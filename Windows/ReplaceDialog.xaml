<Window x:Class="Jade.Windows.ReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace" Height="265" Width="540"
        Background="#1E1E1E"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <!-- Button Style Removed (Using Global) -->
        
        <!-- TextBox Style Removed (Using Global) -->
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    
    <Border BorderThickness="1" BorderBrush="#3E3E42" CornerRadius="{DynamicResource GlobalCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#252526" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" CornerRadius="{DynamicResource GlobalCornerRadius}">
                <TextBlock Text="Replace" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="15,12,15,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Find Input -->
                <TextBlock Grid.Row="0" Text="Find what:" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="FindTextBox" Grid.Row="1" KeyDown="OnSearchKeyDown" Margin="0,0,0,8" TextChanged="OnSearchTextChanged"/>
                
                <!-- Replace Input -->
                <TextBlock Grid.Row="2" Text="Replace with:" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="ReplaceTextBox" Grid.Row="3" Margin="0,0,0,10"/>
                
                <!-- Options -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,12">
                    <CheckBox x:Name="MatchCaseCheckBox" Content="Match case" Margin="0,0,20,0" Click="OnOptionChanged"/>
                    <CheckBox x:Name="WholeWordCheckBox" Content="Whole word" Click="OnOptionChanged"/>
                </StackPanel>
                
                <!-- Buttons -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button x:Name="FindNextButton" Style="{StaticResource ModernButtonStyle}" Content="Find Next" Click="OnFindNext" Margin="0,0,8,0" Width="110" Height="38" Padding="12,0"/>
                    <Button x:Name="ReplaceButton" Style="{StaticResource ModernButtonStyle}" Content="Replace" Click="OnReplace" Margin="0,0,8,0" Width="110" Height="38" Padding="12,0"/>
                    <Button x:Name="ReplaceAllButton" Style="{StaticResource ModernButtonStyle}" Content="Replace All" Click="OnReplaceAll" Margin="0,0,8,0" Width="110" Height="38" Padding="12,0"/>
                    <Button x:Name="CloseButton" Style="{StaticResource ModernButtonStyle}" Content="Close" Click="OnClose" Width="90" Height="38" Padding="12,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
