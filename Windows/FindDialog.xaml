<Window x:Class="Jade.Windows.FindDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find" Height="200" Width="520"
        Background="#1E1E1E"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <!-- Button Style Removed (Using Global) -->
        
        <!-- TextBox Style Removed (Using Global) -->
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    
    <Border BorderThickness="1" BorderBrush="#3E3E42" CornerRadius="{DynamicResource GlobalCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#252526" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" CornerRadius="{DynamicResource GlobalCornerRadius}">
                <TextBlock Text="Find" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Search Input -->
                <TextBlock Grid.Row="0" Text="Find what:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="SearchTextBox" Grid.Row="1" KeyDown="OnSearchKeyDown" TextChanged="OnSearchTextChanged"/>
                
                <!-- Options -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox x:Name="MatchCaseCheckBox" Content="Match case" Margin="0,0,15,0" Click="OnOptionChanged"/>
                    <CheckBox x:Name="WholeWordCheckBox" Content="Whole word" Click="OnOptionChanged"/>
                </StackPanel>
                
                <!-- Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,15,0,0">
                    <Button x:Name="FindPreviousButton" Style="{StaticResource ModernButtonStyle}" Content="Find Previous" Click="OnFindPrevious" Margin="0,0,10,0" Width="110" Height="38" Padding="12,0"/>
                    <Button x:Name="FindNextButton" Style="{StaticResource ModernButtonStyle}" Content="Find Next" Click="OnFindNext" Margin="0,0,10,0" Width="110" Height="38" Padding="12,0"/>
                    <Button x:Name="CloseButton" Style="{StaticResource ModernButtonStyle}" Content="Close" Click="OnClose" Width="90" Height="38" Padding="12,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
