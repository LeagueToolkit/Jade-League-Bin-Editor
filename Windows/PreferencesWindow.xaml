<Window x:Class="Jade.Windows.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jade Preferences" Height="500" Width="800"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>
    
    <Border BorderThickness="1" BorderBrush="#3E3E42" CornerRadius="{DynamicResource GlobalCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#252526" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" CornerRadius="{DynamicResource GlobalCornerRadius}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <Image Source="/jade.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Jade Preferences" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Preferences" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="Configure your experience (Placeholder)" FontSize="16" Foreground="#888888"/>
                </StackPanel>

                <!-- Placeholder Content -->
                <Border Grid.Row="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE115;" FontFamily="Segoe MDL2 Assets" FontSize="48" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                        <TextBlock Text="Preference settings will be added here soon." FontSize="18" Foreground="#888888" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
        
                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Close" Click="OnClose" Background="#3E3E42"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
