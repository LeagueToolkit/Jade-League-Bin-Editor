<Window x:Class="Jade.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Jade" Height="380" Width="600"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">
    
    <Border x:Name="MainBorder" BorderThickness="1" BorderBrush="{DynamicResource SubtleBorderBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" CornerRadius="{DynamicResource GlobalCornerRadius}">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Image Source="/jade.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TitleText" Text="About Jade" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource WindowControlButtonStyle}" Content="✕" Width="30" Height="30" Click="OnClose" 
                            Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0"
                            FontSize="14" HorizontalAlignment="Right" VerticalContentAlignment="Center"/>
                </Grid>
            </Border>
            
            <!-- Two Column Content -->
            <Grid Grid.Row="1" Margin="20,15,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left Column: App Info -->
                <StackPanel Grid.Column="0">
                    
                    <!-- App Icon and Name -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Image Source="/jade.ico" Width="56" Height="56" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AppNameText" Text="Jade" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" 
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock x:Name="SubtitleText" Text="BIN Editor for League of Legends" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" 
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Version -->
                    <Border x:Name="VersionBorder" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="VersionLabel" Text="Version" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                            <TextBlock x:Name="VersionText" Text="1.0.0" FontSize="15" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Creator -->
                    <Border x:Name="CreatorBorder" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="10">
                        <StackPanel>
                            <TextBlock x:Name="CreatorLabel" Text="Created by" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                            <TextBlock x:Name="CreatorText" Text="budlibu500" FontSize="15" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
                
                <!-- Right Column: Support Section -->
                <Border x:Name="SupportBorder" Grid.Column="2" Background="{DynamicResource TitleBarBackgroundBrush}" CornerRadius="{DynamicResource GlobalCornerRadius}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock x:Name="SupportTitle" Grid.Row="0" Text="Support" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="SupportText" Grid.Row="1" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" LineHeight="18">
                            Thank you to all the supporters who helped make this project possible!
                        </TextBlock>
                        
                        <TextBlock x:Name="ThanksLabel" Grid.Row="2" Text="Special Thanks" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" Margin="0,12,0,6"/>
                        
                        <!-- Scrollable Supporters List -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                            <TextBlock x:Name="SupportersList" FontSize="12" Foreground="#DCDCAA" LineHeight="20">
• konradosj<LineBreak/>
• hellgoat2
                            </TextBlock>
                        </ScrollViewer>
                    </Grid>
                </Border>
                
            </Grid>
        </Grid>
    </Border>
</Window>
